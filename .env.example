PORT=3001
HOST=127.0.0.1

# IMPORTANT: Ensure these point to a valid MySQL instance
DB_HOST=localhost
DB_PORT=3306
DB_NAME=take_one
DB_USER=root
DB_PASSWORD=change_this_password

# CRITICAL: This is used for signing JWT session tokens.
# Use a long, random string.
JWT_SECRET=replace_with_a_long_random_secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=verified_sender@example.com
SMTP_PASS=verified_sender_app_password
MAIL_FROM=TAKE ONE <verified_sender@example.com>

MODERATOR_EMAILS=admin@example.com
