# Server Configuration
PORT=3001
HOST=127.0.0.1
NODE_ENV=development

# Database Configuration (Option A: Separate variables)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=take_one
DB_USER=root
DB_PASSWORD=your_password_here
DB_SSL=false # Set to true for production DBs requiring SSL (Aiven, DigitalOcean, etc.)

# Database Configuration (Option B: Connection String)
# DATABASE_URL=mysql://user:password@host:port/database?sslmode=require

# Authentication
# CRITICAL: Use a long, random string for JWT_SECRET
JWT_SECRET=replace_with_a_long_random_secret_for_production

# Email (SMTP) Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
MAIL_FROM="TAKE ONE <your_email@gmail.com>"

# App Settings
ALLOWED_ORIGINS=http://localhost:3000,https://take-one-nexus.vercel.app
MODERATOR_EMAILS=admin@example.com

