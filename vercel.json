{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/((?!admin|api|_next|static|favicon.ico).*\\.htm)",
      "destination": "/server.js"
    }
  ]
}
