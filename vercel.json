{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/_next/(.*)",
      "dest": "/_next/$1"
    },
    {
      "src": "/admin(/(.*)|$)",
      "dest": "/admin$1"
    },
    {
      "src": "/profile",
      "dest": "/profile"
    },
    {
      "src": "/crew",
      "dest": "/crew"
    },
    {
      "src": "/legal",
      "dest": "/legal"
    },
    {
      "src": "/moderation",
      "dest": "/moderation"
    },
    {
      "src": "/chat",
      "dest": "/chat"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/styles/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/scripts/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/((?!admin|api|_next|profile|crew|legal|moderation|chat).*)",
      "dest": "server.js"
    }
  ]
}
