{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/project",
      "destination": "/project.htm"
    },
    {
      "source": "/",
      "destination": "/project.htm"
    }
  ]
}
